# Root .gitignore for the monorepo

# Node
node_modules/

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*
lerna-debug.log*

# Dependency caches
/.pnp*
/.pnpm-debug.log

# Build outputs
dist/
build/
dist-ssr/

# Vite
.vite/

# TypeScript
*.tsbuildinfo

# Coverage and test output
coverage/
.nyc_output/

# Environment
.env
.env.*

# OS files
.DS_Store
Thumbs.db

# Editors and IDEs
.vscode/
.idea/

# Misc
.cache/
.parcel-cache/
.eslintcache
